  { "id": "m-058", "type": "math", "subtype": "word-problem", "question": "Two numbers have a sum of 50 and a product of 600. What are the numbers?", "options": ["20 and 30", "25 and 25", "15 and 35", "10 and 40"], "answer": "20 and 30" },
  { "id": "m-059", "type": "math", "subtype": "word-problem", "question": "A jacket costs $75 plus 8% sales tax. What is the total cost?", "options": ["$81", "$80", "$83", "$78"], "answer": "$81" },
  { "id": "m-060", "type": "math", "subtype": "word-problem", "question": "If the area of a circle is 36π, what is its radius?", "options": ["6", "9", "12", "3"], "answer": "6" },

  { "id": "m-061", "type": "math", "subtype": "fractions-percentages", "question": "What is 2/5 of 75?", "options": ["30", "25", "35", "40"], "answer": "30" },
  { "id": "m-062", "type": "math", "subtype": "fractions-percentages", "question": "Convert 0.375 to a fraction in lowest terms.", "options": ["3/8", "3/7", "5/8", "4/9"], "answer": "3/8" },
  { "id": "m-063", "type": "math", "subtype": "fractions-percentages", "question": "What is 125% of 80?", "options": ["100", "90", "110", "120"], "answer": "100" },
  { "id": "m-064", "type": "math", "subtype": "fractions-percentages", "question": "If 40% of x is 28, what is x?", "options": ["70", "60", "80", "56"], "answer": "70" },
  { "id": "m-065", "type": "math", "subtype": "fractions-percentages", "question": "What is 3/7 + 2/7?", "options": ["5/7", "6/7", "1/7", "4/7"], "answer": "5/7" },
  { "id": "m-066", "type": "math", "subtype": "fractions-percentages", "question": "A number is 20% more than 50. What is the number?", "options": ["60", "55", "65", "70"], "answer": "60" },
  { "id": "m-067", "type": "math", "subtype": "fractions-percentages", "question": "What is 2/3 of 2/3?", "options": ["4/9", "4/6", "1/3", "2/9"], "answer": "4/9" },
  { "id": "m-068", "type": "math", "subtype": "fractions-percentages", "question": "By what percentage is 80 more than 64?", "options": ["25%", "20%", "16%", "30%"], "answer": "25%" },
  { "id": "m-069", "type": "math", "subtype": "fractions-percentages", "question": "What is (1/2) ÷ (3/4)?", "options": ["2/3", "3/8", "1/6", "4/6"], "answer": "2/3" },
  { "id": "m-070", "type": "math", "subtype": "fractions-percentages", "question": "If 3/5 of a number is 36, what is the number?", "options": ["60", "54", "72", "48"], "answer": "60" },

  { "id": "l-001", "type": "logic", "subtype": "deduction", "question": "All dogs are animals. Rex is a dog. Therefore:", "options": ["Rex is an animal", "Rex is a pet", "Rex is a mammal", "Rex can bark"], "answer": "Rex is an animal" },
  { "id": "l-002", "type": "logic", "subtype": "deduction", "question": "No fish can live on land. Nemo is a fish. Therefore:", "options": ["Nemo cannot live on land", "Nemo lives in water", "Nemo is a marine animal", "Nemo is small"], "answer": "Nemo cannot live on land" },
  { "id": "l-003", "type": "logic", "subtype": "deduction", "question": "All squares are rectangles. All rectangles have four sides. Therefore:", "options": ["All squares have four sides", "All rectangles are squares", "Some squares are not rectangles", "Rectangles are squares"], "answer": "All squares have four sides" },
  { "id": "l-004", "type": "logic", "subtype": "deduction", "question": "If it rains, the ground gets wet. The ground is wet. Therefore:", "options": ["It may or may not have rained", "It definitely rained", "It did not rain", "The rain stopped"], "answer": "It may or may not have rained" },
  { "id": "l-005", "type": "logic", "subtype": "deduction", "question": "All roses are flowers. All flowers need water. Therefore:", "options": ["All roses need water", "All water has roses", "Some flowers are roses", "Roses are the only flowers"], "answer": "All roses need water" },
  { "id": "l-006", "type": "logic", "subtype": "deduction", "question": "No mammal is cold-blooded. All snakes are cold-blooded. Therefore:", "options": ["No snake is a mammal", "All mammals are snakes", "Some snakes are mammals", "Snakes are not animals"], "answer": "No snake is a mammal" },
  { "id": "l-007", "type": "logic", "subtype": "ordering", "question": "Sarah is taller than Bob. Bob is taller than Carol. Therefore:", "options": ["Sarah is taller than Carol", "Carol is taller than Sarah", "Bob is the shortest", "Sarah is the shortest"], "answer": "Sarah is taller than Carol" },
  { "id": "l-008", "type": "logic", "subtype": "deduction", "question": "All vegetables are healthy. Broccoli is a vegetable. Therefore:", "options": ["Broccoli is healthy", "Broccoli is the healthiest", "All healthy things are vegetables", "Healthy things are vegetables"], "answer": "Broccoli is healthy" },
  { "id": "l-009", "type": "logic", "subtype": "deduction", "question": "If A > B and B > C, then:", "options": ["A > C", "C > A", "A = C", "B > A"], "answer": "A > C" },
  { "id": "l-010", "type": "logic", "subtype": "deduction", "question": "Some birds can fly. Penguins are birds. Therefore:", "options": ["Penguins may or may not be able to fly", "Penguins can fly", "All penguins fly", "Penguins are not birds"], "answer": "Penguins may or may not be able to fly" },
  { "id": "l-011", "type": "logic", "subtype": "deduction", "question": "All members of Club A are also members of Club B. Jake is a member of Club B. Therefore:", "options": ["Jake may or may not be in Club A", "Jake is definitely in Club A", "Jake is not in Club A", "Jake runs Club B"], "answer": "Jake may or may not be in Club A" },
  { "id": "l-012", "type": "logic", "subtype": "deduction", "question": "In a group of 30, 18 play football and 15 play basketball. At least how many play both?", "options": ["3", "5", "7", "10"], "answer": "3" },
  { "id": "l-013", "type": "logic", "subtype": "deduction", "question": "All Bloops are Razzies. All Razzies are Lazzies. Therefore:", "options": ["All Bloops are Lazzies", "All Lazzies are Bloops", "No Bloops are Lazzies", "Some Lazzies are Bloops"], "answer": "All Bloops are Lazzies" },
  { "id": "l-014", "type": "logic", "subtype": "ordering", "question": "Anna is older than Ben. Charlie is younger than Anna. Ben is older than Charlie. Who is youngest?", "options": ["Charlie", "Ben", "Anna", "Cannot be determined"], "answer": "Charlie" },
  { "id": "l-015", "type": "logic", "subtype": "deduction", "question": "If P implies Q, and Q implies R, then:", "options": ["P implies R", "R implies P", "P and R are unrelated", "Q implies P"], "answer": "P implies R" },
  { "id": "l-016", "type": "logic", "subtype": "deduction", "question": "All lawyers passed the bar exam. Some lawyers work at BigFirm. Therefore:", "options": ["Some people who passed the bar work at BigFirm", "All people at BigFirm passed the bar", "No one at BigFirm passed the bar", "All bar passers work at BigFirm"], "answer": "Some people who passed the bar work at BigFirm" },
  { "id": "l-017", "type": "logic", "subtype": "ordering", "question": "In a race, Mike finished before Joe. Sam finished after Lisa but before Mike. What is the correct finishing order?", "options": ["Lisa, Sam, Mike, Joe", "Joe, Mike, Sam, Lisa", "Mike, Sam, Lisa, Joe", "Sam, Lisa, Mike, Joe"], "answer": "Lisa, Sam, Mike, Joe" },
  { "id": "l-018", "type": "logic", "subtype": "deduction", "question": "If not A, then B. A is true. Therefore:", "options": ["B may or may not be true", "B is definitely true", "B is definitely false", "A and B are equal"], "answer": "B may or may not be true" },
  { "id": "l-019", "type": "logic", "subtype": "deduction", "question": "Every manager has a team. No team has zero members. Therefore:", "options": ["Every manager has at least one team member", "Some managers have empty teams", "Teams exist without managers", "Managers are team members"], "answer": "Every manager has at least one team member" },
  { "id": "l-020", "type": "logic", "subtype": "ordering", "question": "Alex has more books than Beth. Beth has more books than Carl. Carl has more books than Dana. Who has the fewest books?", "options": ["Dana", "Carl", "Beth", "Alex"], "answer": "Dana" },
  { "id": "l-021", "type": "logic", "subtype": "deduction", "question": "If it is a weekday, Jane goes to work. Today Jane is not at work. Therefore:", "options": ["Today is not a weekday", "Today is a weekday", "Jane quit her job", "Jane is sick"], "answer": "Today is not a weekday" },
  { "id": "l-022", "type": "logic", "subtype": "deduction", "question": "All politicians are public figures. Some public figures are celebrities. Therefore:", "options": ["Some politicians may be celebrities", "All politicians are celebrities", "No politicians are celebrities", "All celebrities are politicians"], "answer": "Some politicians may be celebrities" },
  { "id": "l-023", "type": "logic", "subtype": "deduction", "question": "Three boxes are labeled incorrectly. Box 3 is labeled 'Mixed'. You draw one fruit from Box 3 and it's an apple. What does Box 3 actually contain?", "options": ["Only apples", "Only oranges", "Mixed fruits", "Cannot be determined"], "answer": "Only apples" },
  { "id": "l-024", "type": "logic", "subtype": "ordering", "question": "Mark scores higher than Paul. Paul scores higher than Quinn. Quinn scores higher than Rachel. Who scored second highest?", "options": ["Paul", "Mark", "Quinn", "Rachel"], "answer": "Paul" },
  { "id": "l-025", "type": "logic", "subtype": "deduction", "question": "If A is true, then B is true. If B is true, then C is false. A is true. What can we conclude about C?", "options": ["C is false", "C is true", "C may be true or false", "B is false"], "answer": "C is false" },
  { "id": "l-026", "type": "logic", "subtype": "deduction", "question": "No accountants are pilots. All pilots have licenses. Therefore:", "options": ["Some people with licenses are not accountants", "All accountants have licenses", "No accountant has a license", "Pilots are accountants"], "answer": "Some people with licenses are not accountants" },
  { "id": "l-027", "type": "logic", "subtype": "spatial-reasoning", "question": "A is north of B. C is east of B. D is south of C. In which direction is A from D?", "options": ["Northwest", "Northeast", "Southwest", "Southeast"], "answer": "Northwest" },
  { "id": "l-028", "type": "logic", "subtype": "ordering", "question": "There are 4 people: W, X, Y, Z. W is first. Z is last. X is before Y. What is the order?", "options": ["W, X, Y, Z", "W, Y, X, Z", "X, W, Y, Z", "Z, X, Y, W"], "answer": "W, X, Y, Z" },
  { "id": "l-029", "type": "logic", "subtype": "deduction", "question": "Every mystery novel is on the top shelf. This book is not on the top shelf. Therefore:", "options": ["This book is not a mystery novel", "This book is a mystery novel", "All top-shelf books are mystery novels", "This is not a book"], "answer": "This book is not a mystery novel" },
  { "id": "l-030", "type": "logic", "subtype": "ordering", "question": "Tom is heavier than Jim. Mike is lighter than Tom. Jim and Mike weigh the same. Who is heaviest?", "options": ["Tom", "Jim", "Mike", "They all weigh the same"], "answer": "Tom" },
  { "id": "l-031", "type": "logic", "subtype": "deduction", "question": "Every student in the class passed. Kevin is in the class. Therefore:", "options": ["Kevin passed", "Kevin may have failed", "Kevin is not a student", "The class is easy"], "answer": "Kevin passed" },
  { "id": "l-032", "type": "logic", "subtype": "deduction", "question": "If you study hard, you will pass. You did not pass. Therefore:", "options": ["You did not study hard", "You studied hard", "Studying doesn't help", "You will pass next time"], "answer": "You did not study hard" },
  { "id": "l-033", "type": "logic", "subtype": "deduction", "question": "Some doctors are researchers. All researchers publish papers. Therefore:", "options": ["Some doctors publish papers", "All doctors publish papers", "No doctors publish papers", "All paper publishers are doctors"], "answer": "Some doctors publish papers" },
  { "id": "l-034", "type": "logic", "subtype": "ordering", "question": "Blue is heavier than Red. Green weighs less than Blue. Red and Green weigh the same. Which is heaviest?", "options": ["Blue", "Red", "Green", "Red and Green together"], "answer": "Blue" },
  { "id": "l-035", "type": "logic", "subtype": "deduction", "question": "If a shape is a square, it has 4 equal sides. This shape has 4 equal sides. Therefore:", "options": ["This shape may or may not be a square", "This shape is definitely a square", "This shape is not a square", "Squares don't exist"], "answer": "This shape may or may not be a square" },
  { "id": "l-036", "type": "logic", "subtype": "deduction", "question": "None of the cats in the shelter are vaccinated. Whiskers is vaccinated. Therefore:", "options": ["Whiskers is not in the shelter", "Whiskers is in the shelter", "Whiskers is a cat", "Whiskers needs vaccinating"], "answer": "Whiskers is not in the shelter" },
  { "id": "l-037", "type": "logic", "subtype": "deduction", "question": "5 students take a test. 3 pass and 2 fail. Maria is one of the students. Therefore:", "options": ["Maria may have passed or failed", "Maria passed", "Maria failed", "Maria didn't take the test"], "answer": "Maria may have passed or failed" },
  { "id": "l-038", "type": "logic", "subtype": "deduction", "question": "All city buses are numbered. Route 42 is a city bus. Therefore:", "options": ["Route 42 is numbered", "Route 42 is not a bus", "City buses are not numbered", "Route 42 has 42 stops"], "answer": "Route 42 is numbered" },
  { "id": "l-039", "type": "logic", "subtype": "ordering", "question": "Mary is to the left of John. John is to the left of Peter. Therefore:", "options": ["Mary is to the left of Peter", "Peter is to the left of Mary", "Mary and Peter are adjacent", "John is rightmost"], "answer": "Mary is to the left of Peter" },
  { "id": "l-040", "type": "logic", "subtype": "deduction", "question": "All computers need electricity. My tablet needs electricity. Therefore:", "options": ["My tablet may or may not be a computer", "My tablet is a computer", "My tablet is not a computer", "All devices need electricity"], "answer": "My tablet may or may not be a computer" },

